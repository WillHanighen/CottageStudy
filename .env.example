# --- App ---
NODE_ENV=development
PORT=3000
ORIGIN=https://study.cottageindustries.xyz

# --- Persistence ---
# Path to the SQLite database file. Mount this directory as a volume in production.
DB_PATH=./data/study.db

# --- Clerk auth ---
# Get these from https://dashboard.clerk.com (Configure > API Keys).
# Configure the OAuth providers (Google + GitHub) in Clerk's "User & Authentication > Social Connections" tab.
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Cloudflare Turnstile ---
# Get these from https://dash.cloudflare.com (Turnstile).
# Configure the site widget for the study.cottageindustries.xyz hostname.
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_site_key
TURNSTILE_SECRET_KEY=0x4AAAAAAA_secret_key
